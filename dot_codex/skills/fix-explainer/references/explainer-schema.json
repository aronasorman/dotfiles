{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex.invalid/fix-explainer/explainer-schema.json",
  "title": "Fix explainer evidence manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "title",
    "problem",
    "context",
    "evidence",
    "proposed_fix",
    "verification",
    "takeaway"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "problem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symptom", "expected", "diagnosis"],
      "properties": {
        "symptom": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "expected": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "bridges": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "body"],
            "properties": {
              "label": {
                "type": "string",
                "minLength": 1,
                "pattern": "\\S"
              },
              "body": {
                "type": "string",
                "minLength": 1,
                "pattern": "\\S"
              }
            }
          }
        },
        "diagnosis": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_role", "flow"],
      "properties": {
        "file_role": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "flow": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "source_sha256",
          "start_line",
          "end_line",
          "focus_lines",
          "situation",
          "mechanism",
          "implication",
          "gotcha"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "source_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "start_line": {
            "type": "integer",
            "minimum": 1
          },
          "end_line": {
            "type": "integer",
            "minimum": 1
          },
          "focus_lines": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "integer",
              "minimum": 1
            }
          },
          "situation": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "mechanism": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "implication": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "gotcha": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          }
        }
      }
    },
    "proposed_fix": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "start_line",
            "end_line",
            "rationale",
            "unchanged_behavior",
            "risks"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1,
              "pattern": "\\S"
            },
            "start_line": {
              "type": "integer",
              "minimum": 1
            },
            "end_line": {
              "type": "integer",
              "minimum": 1
            },
            "replacement": {
              "type": "string",
              "minLength": 1,
              "pattern": "\\S"
            },
            "unified_diff": {
              "type": "string",
              "minLength": 1,
              "pattern": "\\S"
            },
            "rationale": {
              "type": "string",
              "minLength": 1,
              "pattern": "\\S"
            },
            "unchanged_behavior": {
              "type": "string",
              "minLength": 1,
              "pattern": "\\S"
            },
            "risks": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "\\S"
              }
            }
          },
          "oneOf": [
            {
              "required": ["replacement"]
            },
            {
              "required": ["unified_diff"]
            }
          ]
        }
      ]
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "source", "result", "status"],
        "properties": {
          "claim": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "source": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "result": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "status": {
            "type": "string",
            "enum": ["verified", "not_run", "unsupported"]
          }
        }
      }
    },
    "takeaway": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    }
  }
}
